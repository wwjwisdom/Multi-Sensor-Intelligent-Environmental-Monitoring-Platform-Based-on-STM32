# 配置文件示例
# 复制此文件为 config.yaml 并填入实际值

server:
  port: 8080
  mode: debug

amqp:
  enabled: true
  host: "你的AMQP_HOST"
  port: 5671
  access_key_id: "你的AccessKeyID"
  access_key_secret: "你的AccessKeySecret"
  consumer_group_id: "你的消费组ID"
  iot_instance_id: "你的实例ID"

mqtt:
  broker: "你的MQTT Broker"
  port: 1883
  # ... 其他MQTT配置

storage:
  data_dir: "./Data/history"
  retention_days: 180  # 保留180天

# TimescaleDB 配置（可选）
# 设置 enabled: true 启用 TimescaleDB 作为历史数据存储
timescaledb:
  enabled: false
  host: "localhost"
  port: 5432
  user: "postgres"
  password: "your_password"
  dbname: "sensor_db"
  sslmode: "disable"
  max_open_conns: 25
  max_idle_conns: 5
  conn_max_lifetime: 300

alarm:
  enabled: true
  check_interval: 5s

logging:
  level: "info"
  path: "./Data/logs/app.log"
